 fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-bell h-5 w-5 text-primary\" aria-hidden=\"true\"><path d=\"M10.268 21a2 2 0 0 0 3.464 0\"></path><path d=\"M3.262 15.326A1 1 0 0 0 4 17h16a1 1 0 0 0 .74-1.673C19.41 13.956 18 12.499 18 8A6 6 0 0 0 6 8c0 4.499-1.411 5.956-2.738 7.326\"></path></svg></div><h3 class=\"font-semibold\">Instant Notifications</h3><p class=\"text-sm text-muted-foreground mt-1\">Get real-time alerts for messages, price drops, and new matching listings.</p></div></div><div data-slot=\"card\" class=\"bg-card text-card-foreground flex flex-col gap-6 rounded-xl border py-6 shadow-sm hover:shadow-md transition-shadow\"><div data-slot=\"card-content\" class=\"p-5\"><div class=\"h-10 w-10 rounded-lg bg-primary/10 flex items-center justify-center mb-3\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-message-circle h-5 w-5 text-primary\" aria-hidden=\"true\"><path d=\"M7.9 20A9 9 0 1 0 4 16.1L2 22Z\"></path></svg></div><h3 class=\"font-semibold\">Chat on the Go</h3><p class=\"text-sm text-muted-foreground mt-1\">Full messaging support so you can negotiate deals anywhere, anytime.</p></div></div><div data-slot=\"card\" class=\"bg-card text-card-foreground flex flex-col gap-6 rounded-xl border py-6 shadow-sm hover:shadow-md transition-shadow\"><div data-slot=\"card-content\" class=\"p-5\"><div class=\"h-10 w-10 rounded-lg bg-primary/10 flex items-center justify-center mb-3\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-camera h-5 w-5 text-primary\" aria-hidden=\"true\"><path d=\"M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 