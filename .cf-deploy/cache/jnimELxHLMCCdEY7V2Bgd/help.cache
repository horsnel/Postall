\":\\\"card-content\\\",\\\"className\\\":\\\"p-0\\\",\\\"children\\\":[\\\"$\\\",\\\"$L2c\\\",null,{\\\"type\\\":\\\"single\\\",\\\"collapsible\\\":true,\\\"className\\\":\\\"w-full\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2d\\\",\\\"0\\\",{\\\"value\\\":\\\"getting-started-0\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2e\\\",null,{\\\"className\\\":\\\"px-6 text-left\\\",\\\"children\\\":\\\"Do I need to create an account to use PostAll?\\\"}],[\\\"$\\\",\\\"$L2f\\\",null,{\\\"className\\\":\\\"px-6 text-muted-foreground leading-relaxed\\\",\\\"children\\\":\\\"You can browse all listings, tasks, and services on PostAll without creating an account. However, to post tasks, apply for work, send messages, make purchases, or use any of our 24 tools, you will need to create a free account. The sign-up process is quick and only requires basic information like your name and email address.\\\"}]]}],[\\\"$\\\",\\\"$L2d\\\",\\\"1\\\",{\\\"value\\\":\\\"getting-started-1\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2e\\\",null,{\\\"className\\\":\\\"px-6 text-left\\\",\\\"children\\\":\\\"How do I create an account on PostAll?\\\"}],[\\\"$\\\",\\\"$L2f\\\",null,{\\\"className\\\":\\\"px-6 text-muted-foreground leading-relaxed\\\",\\\"children\\\":\\\"To create an account, click the 'Log In' button in the top-right corner of any page and select 'Sign Up.' You can register using your email address or phone number. After verifying your contact information, you can set up your profile, add a photo, and start using all the features available on the platform right away.\\\"}]]}],[\\\"$\\\",\\\"$L2d\\\",\\\"2\\\",{\\\"value\\\":\\\"getting-started-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2e\\\",null,{\\\"className\\\":\\\"px-6 text-left\\\",\\\"children\\\":\\\"What cities is PostAll available in?\\\"}],[\\\"$\\\",\\\"$L2f\\\",null,{\\\"className\\\":\\\"px-6 text-muted-foreground leading-relaxed\\\",\\\"children\\\":\\\"PostAll is currently available in over 25 cities across Nigeria including Lagos, Abuja, Port Harcourt, Ibadan, and many more. We are constantly expanding to new cities, so check back regularly or follow us on social media for updates on new locations.\\\"}]]}],[\\\"$\\\",\\\"$L2d\\\",\\\"3\\\",{\\\"value\\\":\\\"getting-started-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2e\\\",null,{\\\"className\\\":\\\"px-6 text-left\\\",\\\"children\\\":\\\"Is PostAll free to use?\\\"}],[\\\"$\\\",\\\"$L2f\\\",null,{\\\"className\\\":\\\"px-6 text-muted-foreground leading-relaxed\\\",\\\"children\\\":\\\"Yes, PostAll is completely free to get started. You can browse listings, post tasks, apply for jobs, and use our basic tools at no cost. We only charge a small platform fee of 5% on completed transactions and a 2% escrow protection fee. There are no subscription fees, no listing fees, and no hidden charges whatsoever.\\\"}]]}],[\\\"$\\\",\\\"$L2d\\\",\\\"4\\\",{\\\"value\\\":\\\"getting-started-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2e\\\",null,{\\\"className\\\":\\\"px-6 text-left\\\",\\\"children\\\":\\\"What are the 24 tools available on PostAll?\\\"}],[\\\"$\\\",\\\"$L2f\\\",null,{\\\"className\\\":\\\"px-6 text-muted-foreground leading-relaxed\\\",\\\"children\\\":\\\"Our 24 built-in tools include AI Assistant, Price Check, Safe Spots, Proof Cam, Escrow Calculator, Task Timer, Invoice Generator, Rating System, Verified Profiles, Emergency Button, Dispute Resolver, Meeting Scheduler, Delivery Tracker, Background Check, Portfolio Builder, Skill Matcher, Budget Planner, Negotiation Helper, Feedback Hub, Community Forum, Market Analytics, Job Board, Service Directory, and Crypto Wallet.\\\"}]]}]]}]}]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"13:[\\\"$\\\",\\\"div\\\",\\\"posting-tasks\\\",{\\\"id\\\":\\\"posting-tasks\\\",\\\"className\\\":\\\"mb-12 scroll-mt-24\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-3 mb-6\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"h-10 w-10 rounded-lg bg-teal-100 text-teal-700 flex items-center justify-center\\\",\\\"children\\\":\\\"$11:props:children:1:props:children:props:children:props:children:0:props:children\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-2xl font-bold\\\",\\\"children\\\":\\\"Posting Tasks\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-sm text-muted-foreground\\\",\\\"children\\\":\\\"Everything you need to know about creating and managing tasks\\\"}]]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"data-slot\\\":\\\"card\\\",\\\"className\\\":\\\"bg-card text-card-foreground flex flex-col gap-6 rounded-xl border py-6 shadow-sm\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"data-slot\\\":\\\"card-content\\\",\\\"className\\\":\\\"p-0\\\",\\\"children\\\":[\\\"$\\\",\\\"$L2c\\\",null,{\\\"type\\\":\\\"single\\\",\\\"collapsible\\\":true,\\\"className\\\":\\\"w-full\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2d\\\",\\\"0\\\",{\\\"value\\\":\\\"posting-tasks-0\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2e\\\",null,{\\\"className\\\":\\\"px-6 text-left\\\",\\\"children\\\":\\\"How do I post a task on PostAll?\\\"}],[\\\"$\\\",\\\"$L2f\\\",null,{\\\"className\\\":\\\"px-6 text-muted-foreground leading-relaxed\\\",\\\"children\\\":\\\"To post a task, click the 'Post a Task' button on the homepage or navigation bar. Fill in the task details including a clear title, detailed description, your budget range, location, deadline, and any specific requirements. You can also add photos to help workers understand exactly what you need. Once submitted, your task will be visible to all users in your area.\\\"}]]}],[\\\"$\\\",\\\"$L2d\\\",\\\"1\\\",{\\\"value\\\":\\\"posting-tasks-1\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2e\\\",null,{\\\"className\\\":\\\"px-6 text-left\\\",\\\"children\\\":\\\"What information should I include in my task description?\\\"}],[\\\"$\\\",\\\"$L2f\\\",null,{\\\"className\\\":\\\"px-6 text-muted-foreground leading-relaxed\\\",\\\"children\\\":\\\"A good task description should include a clear summary of the work needed, specific skills or tools required, the expected timeline and deadline, your budget range, preferred meeting location, and any other relevant details. The more specific you are, the better quality applications you will receive from qualified workers who understand exactly what you need.\\\"}]]}],[\\\"$\\\",\\\"$L2d\\\",\\\"2\\\",{\\\"value\\\":\\\"posting-tasks-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2e\\\",null,{\\\"className\\\":\\\"px-6 text-left\\\",\\\"children\\\":\\\"Can I edit or delete a task after posting it?\\\"}],[\\\"$\\\",\\\"$L2f\\\",null,{\\\"className\\\":\\\"px-6 text-muted-foreground leading-relaxed\\\",\\\"children\\\":\\\"Yes, you can edit your task at any time as long as no one has been selected yet. Go to your Dashboard, click on 'My Tasks,' find the task you want to modify, and click the edit button. If you want to delete a task, you can do so from the same menu. Note that once a worker has been selected and escrow has been funded, the task cannot be deleted, only disputed.\\\"}]]}],[\\\"$\\\",\\\"$L2d\\\",\\\"3\\\",{\\\"value\\\":\\\"posting-tasks-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2e\\\",null,{\\\"className\\\":\\\"px-6 text-left\\\",\\\"children\\\":\\\"How do I choose the right worker for my task?\\\"}],[\\\"$\\\",\\\"$L2f\\\",null,{\\\"className\\\":\\\"px-6 text-muted-foreground leading-relaxed\\\",\\\"children\\\":\\\"Review all applications carefully by checking each worker's profile, ratings, reviews, and completion history. You can message applicants directly through the platform to ask questions and discuss the task before making your decision. Consider their experience level, proposed timeline, and price. Once you've chosen, select them and the escrow process will begin automatically.\\\"}]]}]]}]}]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"14:[\\\"$\\\",\\\"div\\\",\\\"finding-work\\\",{\\\"id\\\":\\\"finding-work\\\",\\\"className\\\":\\\"mb-12 scroll-mt-24\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-3 mb-6\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"h-10 w-10 rounded-lg bg-cyan-100 text-cyan-700 flex items-center justify-center\\\",\\\"children\\\":\\\"$25\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-2xl font-bold\\\",\\\"children\\\":\\\"Finding Work\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-sm text-muted-foreground\\\",\\\"children\\\":\\\"Tips for workers and service providers looking for opportunities\\\"}]]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"data-slot\\\":\\\"card\\\",\\\"className\\\":\\\"bg-card text-card-foreground flex flex-col gap-6 rounded-xl border py-6 shadow-sm\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"data-slot\\\":\\\"card-content\\\",\\\"className\\\":\\\"p-0\\\",\\\"children\\\":[\\\"$\\\",\\\"$L2c\\\",null,{\\\"type\\\":\\\"single\\\",\\\"collapsible\\\":true,\\\"className\\\":\\\"w-full\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2d\\\",\\\"0\\\",{\\\"value\\\":\\\"finding-work-0\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2e\\\",null,{\\\"className\\\":\\\"px-6 text-left\\\",\\\"children\\\":\\\"How do I find tasks that match my skills?\\\"}],[\\\"$\\\",\\\"$L2f\\\",null,{\\\"className\\\":\\\"px-6 text-muted-foreground leading-relaxed\\\",\\\"children\\\":\\\"Browse the 'Find Work' page to see all available tasks filtered by category and location. You can use our Skill Matcher tool to get personalized task recommendations based on your profile and skills. Set up alerts for specific categories so you get notified when new tasks that match your expertise are posted in your area.\\\"}]]}],[\\\"$\\\",\\\"$L2d\\\",\\\"1\\\",{\\\"value\\\":\\\"finding-work-1\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2e\\\",null,{\\\"className\\\":\\\"px-6 text-left\\\",\\\"children\\\":\\\"How do I write a winning application?\\\"}],[\\\"$\\\",\\\"$L2f\\\",null,{\\\"className\\\":\\\"px-6 text-muted-foreground leading-relaxed\\\",\\\"children\\\":\\\"A strong application includes a personalized greeting, specific details about how you'll approach the task, your relevant experience, your proposed timeline, and a competitive but fair price. Avoid generic copy-paste applications. Reference specific details from the task description to show you've read and understood the requirements. Include links to your portfolio or past work if available.\\\"}]]}],[\\\"$\\\",\\\"$L2d\\\",\\\"2\\\",{\\\"value\\\":\\\"finding-work-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2e\\\",null,{\\\"className\\\":\\\"px-6 text-left\\\",\\\"children\\\":\\\"How many tasks can I apply for at once?\\\"}],[\\\"$\\\",\\\"$L2f\\\",null,{\\\"className\\\":\\\"px-6 text-muted-foreground leading-relaxed\\\",\\\"children\\\":\\\"There is no limit to the number of tasks you can apply for simultaneously. However, we recommend focusing on tasks where you have genuine expertise and can deliver quality work on time. Applying for too many tasks without the capacity to complete them can negatively affect your ratings and reputation on the platform over time.\\\"}]]}],[\\\"$\\\",\\\"$L2d\\\",\\\"3\\\",{\\\"value\\\":\\\"finding-work-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2e\\\",null,{\\\"className\\\":\\\"px-6 text-left\\\",\\\"children\\\":\\\"What happens after I'm selected for a task?\\\"}],[\\\"$\\\",\\\"$L2f\\\",null,{\\\"className\\\":\\\"px-6 text-muted-foreground leading-relaxed\\\",\\\"children\\\":\\\"Once selected, you'll receive a notification and the task will move to your 'Active Tasks' in the Dashboard. The buyer's payment will be held in escrow, and you can begin working on the task. Use the platform messaging system to communicate with the buyer, share updates, and coordinate any meetings. Complete the work as agreed, and the escrow funds will be released to you upon confirmation.\\\"}]]}]]}]}]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"15:[\\\"$\\\",\\\"div\\\",\\\"payments-escrow\\\",{\\\"id\\\":\\\"payments-escrow\\\",\\\"className\\\":\\\"mb-12 scroll-mt-24\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-3 mb-6\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"h-10 w-10 rounded-lg bg-amber-100 text-amber-700 flex items-center justify-center\\\",\\\"children\\\":[\\\"$\\\",\\\"svg\\\",null,{\\\"ref\\\":\\\"$undefined\\\",\\\"xmlns\\\":\\\"http://www.w3.org/2000/svg\\\",\\\"width\\\":24,\\\"height\\\":24,\\\"viewBox\\\":\\\"0 0 24 24\\\",\\\"fill\\\":\\\"none\\\",\\\"stroke\\\":\\\"currentColor\\\",\\\"strokeWidth\\\":2,\\\"strokeLinecap\\\":\\\"round\\\",\\\"strokeLinejoin\\\":\\\"round\\\",\\\"className\\\":\\\"lucide lucide-credit-card h-5 w-5\\\",\\\"aria-hidden\\\":\\\"true\\\",\\\"children\\\":[[\\\"$\\\",\\\"rect\\\",\\\"ynyp8z\\\",{\\\"width\\\":\\\"20\\\",\\\"height\\\":\\\"14\\\",\\\"x\\\":\\\"2\\\",\\\"y\\\":\\\"5\\\",\\\"rx\\\":\\\"2\\\"}],[\\\"$\\\",\\\"line\\\",\\\"1b3vmo\\\",{\\\"x1\\\":\\\"2\\\",\\\"x2\\\":\\\"22\\\",\\\"y1\\\":\\\"10\\\",\\\"y2\\\":\\\"10\\\"}],\\\"$undefined\\\"]}]}],[\\\"$\\\",\\\"div\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-2xl font-bold\\\",\\\"children\\\":\\\"Payments \\u0026 Escrow\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-sm text-muted-foreground\\\",\\\"children\\\":\\\"Understanding how payments, fees, and escrow protection work\\\"}]]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"data-slot\\\":\\\"card\\\",\\\"className\\\":\\\"bg-card text-card-foreground flex flex-col gap-6 rounded-xl border py-6 shadow-sm\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"data-slot\\\":\\\"card-content\\\",\\\"className\\\":\\\"p-0\\\",\\\"children\\\":[\\\"$\\\",\\\"$L2c\\\",null,{\\\"type\\\":\\\"single\\\",\\\"collapsible\\\":true,\\\"className\\\":\\\"w-full\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2d\\\",\\\"0\\\",{\\\"value\\\":\\\"payments-escrow-0\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2e\\\",null,{\\\"className\\\":\\\"px-6 text-left\\\",\\\"children\\\":\\\"How does the escrow system work?\\\"}],[\\\"$\\\",\\\"$L2f\\\",null,{\\\"className\\\":\\\"px-6 text-muted-foreground leading-relaxed\\\",\\\"children\\\":\\\"When a buyer agrees to hire you, they deposit the task payment into PostAll's secure escrow account. The funds are held safely and released to you only after the buyer confirms the work is complete or the review period expires. This protects both parties — the buyer knows their money is safe, and you know the funds are available before you start working.\\\"}]]}],[\\\"$\\\",\\\"$L2d\\\",\\\"1\\\",{\\\"value\\\":\\\"payments-escrow-1\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2e\\\",null,{\\\"className\\\":\\\"px-6 text-left\\\",\\\"children\\\":\\\"What fees does PostAll charge?\\\"}],[\\\"$\\\",\\\"$L2f\\\",null,{\\\"className\\\":\\\"px-6 text-muted-foreground leading-relaxed\\\",\\\"children\\\":\\\"PostAll charges two small fees: a 5% platform service fee on completed transactions and a 2% escrow protection fee. These fees are automatically deducted from the transaction amount before funds are released to the seller. For example, on a $100 transaction, the seller receives $93 after fees. There are no subscription fees, listing fees, or hidden charges.\\\"}]]}],[\\\"$\\\",\\\"$L2d\\\",\\\"2\\\",{\\\"value\\\":\\\"payments-escrow-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2e\\\",null,{\\\"className\\\":\\\"px-6 text-left\\\",\\\"children\\\":\\\"How do I withdraw money from my PostAll wallet?\\\"}],[\\\"$\\\",\\\"$L2f\\\",null,{\\\"className\\\":\\\"px-6 text-muted-foreground leading-relaxed\\\",\\\"children\\\":\\\"Go to your Dashboard and click on 'Wallet.' You'll see your available balance, and you can click 'Withdraw' to transfer funds to your linked Nigerian bank account. Bank transfers typically process within 1-3 business days.\\\"}]]}],[\\\"$\\\",\\\"$L2d\\\",\\\"3\\\",{\\\"value\\\":\\\"payments-escrow-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2e\\\",null,{\\\"className\\\":\\\"px-6 text-left\\\",\\\"children\\\":\\\"What payment methods are accepted?\\\"}],[\\\"$\\\",\\\"$L2f\\\",null,{\\\"className\\\":\\\"px-6 text-muted-foreground leading-relaxed\\\",\\\"children\\\":\\\"PostAll accepts bank transfers and debit cards securely processed through Paystack. All transactions are in Nigerian Naira (₦).\\\"}]]}],[\\\"$\\\",\\\"$L2d\\\",\\\"4\\\",{\\\"value\\\":\\\"payments-escrow-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L2e\\\",null,{\\\"className\\\":\\\"px-6 text-left\\\",\\\"children\\\":\\\"What happens if there's a dispute over payment?\\\"}],[\\\"$\\\",\\\"$L2f\\\",null,{\\\"className\\\":\\\"px-6 text-muted-foreground leading-relaxed\\\",\\\"children\\\":\\\"Either party can open a dispute within the review period after a task is marked complete. Our dispute resolution team will review all evidence including messages, Proof Cam images, and transaction history. We aim to resolve disputes within 72 hours, and our decision regarding fund distribution is final. The escrow funds remain safely held until the dispute is resolved.\\\"}]]}]]}]}]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"16:[\\\"$\\\",\\\"div\\\",\\\"account-settings\\\",{\\\"id\\\":\\\"account-settings\\\",\\\"className\\\":\\\"mb-12 scroll-mt-24\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-3 mb-6\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"h-10 w-10 rounded-lg bg-orange-100 text-orange-700 flex items-center justify-center\\\",\\\"children\\\":[\\\"$\\\",\\\"svg\\\",null,{\\\"ref\\\":\\\"$undefined\\\",\\\"xmlns\\\":\\\"http://www.w3.org/2000/svg\\\",\\\"width\\\":24,\\\"height\\\":24,\\\"viewBox\\\":\\\"0 0 24 24\\\",\\\"fill\\\":\\\"none\\\",\\\"stroke\\\":\\\"currentColor\\\",\\\"strokeWidth\\\":2,\\\"strokeLinecap\\\":\\\"round\\\",\